# KATS Environment Configuration
# Copy this file to .env and fill in values before running KATS.
# NEVER commit .env with real credentials.

# Runtime environment: development | simulation | production
KATS_ENV=development

# ---------------------------------------------------------------------------
# KIS OpenAPI Credentials (required for simulation/production)
# ---------------------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_NO=
KIS_HTS_ID=
KIS_ACCOUNT_PRODUCT=01

# Account mode: mock (VTS/paper) or real (live). Default is mock.
KIS_ACCOUNT_TYPE=mock

# ---------------------------------------------------------------------------
# Safety defaults
# ---------------------------------------------------------------------------
# Real orders remain disabled in config/order.live_trading_enabled=false.
# Production startup requires this .env file to exist.
